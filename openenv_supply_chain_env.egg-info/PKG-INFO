├── inference.py                        # Baseline LLM agent — emits [START]/[STEP]/[END] logs
├── validate.py                         # Pre-submission validator (103 checks)
├── openenv.yaml                        # OpenEnv spec config
├── Dockerfile                          # Container definition
└── pyproject.toml                      # Package config
```

